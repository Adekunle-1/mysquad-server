# =============================================================================
# MyGuy Media Server — Environment Variables
# Copy this file to .env and fill in your values.
# Location: MySquad_scripts/my-guy-media-server - Cloud/.env
# NEVER commit your actual .env file.
# =============================================================================


# ── MinIO Object Storage ──────────────────────────────────────────────────────
# Endpoint must include protocol (https:// or http://)
# Example: https://storage.yourdomain.com

MINIO_ENDPOINT=https://storage.yourdomain.com
MINIO_ROOT_USER=your_minio_username
MINIO_ROOT_PASSWORD=your_minio_password

# Bucket name for media files (created automatically if it doesn't exist)
MINIO_BUCKET=myguy-media


# ── n8n Webhook ───────────────────────────────────────────────────────────────
# The n8n webhook URL that receives forwarded media/text payloads
# Find this in your n8n workflow's Webhook node

N8N_WEBHOOK_URL=https://yourdomain.com/webhook/your-webhook-id


# ── Server ────────────────────────────────────────────────────────────────────

PORT=5672

# File size limits in megabytes
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_SIZE_MB=25
