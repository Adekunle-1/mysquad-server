# =============================================================================
# Google Integrated Server — Environment Variables
# Copy this file to .env and fill in your values.
# Location: MySquad_scripts/Google-Integrated - Cloud/.env
# NEVER commit your actual .env file.
# =============================================================================


# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials (OAuth 2.0 Client)

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match the redirect URI registered in Google Cloud Console exactly
GOOGLE_REDIRECT_URI=https://google.yourdomain.com/auth/callback


# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/your_database_name


# ── Token Encryption ──────────────────────────────────────────────────────────
# Fernet symmetric key used to encrypt Google OAuth refresh tokens in the DB.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, all stored tokens become unreadable.
# Store a backup securely.

TOKEN_ENCRYPTION_KEY=your_generated_fernet_key_here


# ── Server ────────────────────────────────────────────────────────────────────

PORT=5671
