    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  r.id,\n  r.tenant_id,\n  r.reminder_text,\n  r.reminder_time,\n  r.next_run_time,\n  r.reminder_type,\n  r.status,\n  r.is_recurring,\n  r.metadata,\n  r.max_runs,\n  r.run_count,\n  r.last_sent_at,\n  t.preferred_name AS user_name,\n  t.telegram_id,\n  t.last_language_style AS user_language,\n  pi.access_token AS bot_token,\n  CASE\n    WHEN r.next_run_time < (NOW() AT TIME ZONE 'Africa/Lagos')\n    THEN EXTRACT(EPOCH FROM (NOW() AT TIME ZONE 'Africa/Lagos') - r.next_run_time)::INTEGER / 60\n    ELSE 0\n  END AS minutes_overdue\nFROM table_13 r\nJOIN table_14 t ON t.id = r.tenant_id\nJOIN table_15 pi\n  ON pi.tenant_id = r.tenant_id\n  AND pi.platform = 'telegram'\n  AND pi.is_active = true\nWHERE r.status = 'pending'\n  AND r.next_run_time <= (NOW() AT TIME ZONE 'Africa/Lagos') + INTERVAL '2 minutes'\n  AND r.next_run_time > (NOW() AT TIME ZONE 'Africa/Lagos') - INTERVAL '5 minutes'\n  AND (r.last_sent_at IS NULL OR r.last_sent_at < r.next_run_time)\nORDER BY r.next_run_time ASC\nFOR UPDATE table_16 r SKIP LOCKED",
        "options": {}
      },
      "id": "__NODE_29__",
      "name": "Fetch Due Reminders1",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -224,
        688
      ],
      "alwaysOutputData": false,
      "credentials": {
        "postgres": {
          "id": "__POSTGRES_CRED_ID",
          "name": "PostgreSQL Credentials"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const reminder = $('Fetch Due Reminders1').item.json;\nconst metadata = reminder.metadata || {};\nconst runCount = (reminder.run_count || 0) + 1;\nconst maxRuns = reminder.max_runs || null;\n\n// Non-recurring: always stop\nif (!reminder.is_recurring) {\n  return { json: { should_create_next: false, reminder_id: reminder.id, tenant_id: reminder.tenant_id, run_count: runCount } };\n}\n\nconst scheduleMode = metadata.schedule_mode || 'interval'; // 'interval' | 'daily_fixed'\n\n// Check max_runs cap (applies to both modes)\nif (maxRuns !== null && runCount >= maxRuns) {\n  return { json: { should_create_next: false, reminder_id: reminder.id, tenant_id: reminder.tenant_id, run_count: runCount } };\n}\n\nlet nextTime;\n\nif (scheduleMode === 'daily_fixed') {\n  // Compute \"tomorrow at fixed_time in Lagos timezone\"\n  const fixedTime = metadata.fixed_time; // e.g. \"08:00\"\n  if (!fixedTime) {\n    return { json: { should_create_next: false, reminder_id: reminder.id, tenant_id: reminder.tenant_id, run_count: runCount, error: 'Missing fixed_time for daily_fixed mode' } };\n  }\n\n  const [hours, minutes] = fixedTime.split(':').map(Number);\n\n  // Get current Lagos time\n  const nowLagos = new Date(new Date().toLocaleString('en-US', { timeZone: 'Africa/Lagos' }));\n  \n  // Build next occurrence: start from table_17 in Lagos, set the fixed time\n  const candidate = new Date(nowLagos);\n  candidate.setHours(hours, minutes, 0, 0);\n\n  // If that time has already passed today, move to tomorrow\n  if (candidate <= nowLagos) {\n    candidate.setDate(candidate.getDate() + 1);\n  }\n\n  // Convert back to UTC ISO string for storage\n  // We reconstruct by using the Lagos offset (+01:00)\n  const lagosOffsetMs = 60 * 60 * 1000; // UTC+1\n  const candidateUTC = new Date(candidate.getTime() - lagosOffsetMs);\n  nextTime = candidateUTC;\n\n} else {\n  // interval mode (existing logic)\n  const intervalMinutes = metadata.interval_minutes;\n  if (!intervalMinutes || intervalMinutes <= 0) {\n    return { json: { should_create_next: false, reminder_id: reminder.id, tenant_id: reminder.tenant_id, run_count: runCount, error: 'Missing interval_minutes' } };\n  }\n\n  const currentTime = new Date(reminder.next_run_time);\n  nextTime = new Date(currentTime.getTime() + intervalMinutes * 60000);\n\n  // Check until date\n  if (metadata.until) {\n    const untilTime = new Date(metadata.until);\n    if (nextTime > untilTime) {\n      return { json: { should_create_next: false, reminder_id: reminder.id, tenant_id: reminder.tenant_id, run_count: runCount } };\n    }\n  }\n}\n\nreturn {\n  json: {\n    should_create_next: true,\n    reminder_id: reminder.id,\n    tenant_id: reminder.tenant_id,\n    reminder_text: reminder.reminder_text,\n    reminder_type: reminder.reminder_type,\n    is_recurring: reminder.is_recurring,\n    metadata: reminder.metadata,\n    max_runs: reminder.max_runs,\n    run_count: runCount,\n    next_reminder_time: nextTime.toISOString()\n  }\n};"
      },
