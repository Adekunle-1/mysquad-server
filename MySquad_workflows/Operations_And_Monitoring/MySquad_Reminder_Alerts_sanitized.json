    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  r.*,\n  u.username as user_name,\n  u.phone_no as phone_no,\n  u.telegram_id as telegram_id,\n  u.interests as user_interests,\n  u.last_language_style as user_language,\n  CASE \n    WHEN r.next_run_time < (NOW() AT TIME ZONE 'Africa/Lagos') THEN \n      EXTRACT(EPOCH FROM (NOW() AT TIME ZONE 'Africa/Lagos') - r.next_run_time)::INTEGER / 60\n    ELSE 0\n  END as minutes_overdue\nFROM table_1 r\nJOIN table_4 u ON r.user_id = u.user_id\nWHERE r.status = 'pending'\n  AND r.next_run_time <= (NOW() AT TIME ZONE 'Africa/Lagos') + INTERVAL '2 minutes'\n  AND r.next_run_time > (NOW() AT TIME ZONE 'Africa/Lagos') - INTERVAL '2 minutes'\n  AND (r.last_sent_at IS NULL OR r.last_sent_at < r.next_run_time)\nORDER BY r.next_run_time ASC;",
