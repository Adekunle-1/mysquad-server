    {
      "parameters": {
        "jsCode": "// Get the original reminder data from table_2 Due Reminders node\nconst reminder = $('Fetch Due Reminders').item.json;\nconst currentTime = new Date(reminder.next_run_time);\nconst metadata = reminder.metadata || {};\n\n// If not recurring, don't create next occurrence\nif (!reminder.is_recurring) {\n  return {\n    json: {\n      chat_id: reminder.chat_id,\n      reminder_text: reminder.reminder_text,\n      reminder_type: reminder.reminder_type,\n      is_recurring: false,\n      metadata: metadata,\n      next_reminder_time: null,\n      should_create_next: false\n    }\n  };\n}\n\n// Get interval from table_3\nconst intervalMinutes = metadata.interval_minutes;\n\n// Validate interval exists\nif (!intervalMinutes || intervalMinutes <= 0) {\n  console.error('Recurring reminder missing interval_minutes in metadata:', reminder.id);\n  return {\n    json: {\n      chat_id: reminder.chat_id,\n      reminder_text: reminder.reminder_text,\n      reminder_type: reminder.reminder_type,\n      is_recurring: reminder.is_recurring,\n      metadata: metadata,\n      next_reminder_time: null,\n      should_create_next: false,\n      error: 'Missing interval_minutes in metadata'\n    }\n  };\n}\n\n// Calculate next occurrence\nconst nextTime = new Date(currentTime);\nnextTime.setMinutes(nextTime.getMinutes() + intervalMinutes);\n\n// Check if we've reached the 'until' time (if specified)\nlet shouldCreateNext = true;\nif (metadata.until) {\n  const untilTime = new Date(metadata.until);\n  if (nextTime > untilTime) {\n    shouldCreateNext = false;\n  }\n}\n\nreturn {\n  json: {\n    // Original reminder fields\n    chat_id: reminder.chat_id,\n    reminder_text: reminder.reminder_text,\n    reminder_type: reminder.reminder_type,\n    is_recurring: reminder.is_recurring,\n    metadata: metadata,\n    \n    // Calculated fields\n    next_reminder_time: nextTime.toISOString(),\n    should_create_next: shouldCreateNext\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -16
      ],
