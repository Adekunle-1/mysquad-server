        "jsCode": "\nconst input = $input.first().json;\nconst tenantId   = input.tenant_id;\nconst businessId = input.business_id;\nif (!tenantId || !businessId) throw new Error('Missing tenant_id or business_id');\n\nconst token = 'msqcat_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 8);\nconst url = '[URL]' + token;\n\nreturn [{ json: { token, tenant_id: tenantId, business_id: businessId, url } }];\n"
