        "operation": "executeQuery",
        "query": "INSERT INTO table_1 (token, tenant_id, business_id, expires_at) VALUES ($1, $2::uuid, $3::uuid, now() + interval '7 days') ON CONFLICT (token) DO NOTHING RETURNING token",
