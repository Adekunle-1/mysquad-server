      "id": "__NODE_6__",
      "name": "Set Bot Display Name",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        192,
        128
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const input     = $('Incoming Payload').first().json;\nconst dbResult  = $('Update table_1 Config').first().json;\nconst newName   = dbResult.agent_name || input.agent_name || '';\n\n// Check if Telegram rename succeeded (if it was attempted)\nlet telegramUpdated = false;\ntry {\n  const tgResult = $('Set Bot Display Name').first().json;\n  telegramUpdated = tgResult?.ok === true;\n} catch(e) {}\n\n// Build response\nconst changes = [];\nif (input.agent_name)     changes.push('agent name \u2192 ' + newName);\nif (input.tone_summary)   changes.push('tone updated');\nif (input.reply_language) changes.push('language \u2192 ' + input.reply_language);\n\nreturn [{\n  json: {\n    success: true,\n    agent_name: newName,\n    tone_profile: dbResult.tone_profile,\n    reply_language: dbResult.reply_language,\n    telegram_display_updated: telegramUpdated,\n    changes_made: changes,\n    message: changes.length > 0\n      ? 'Updated: ' + changes.join(', ') + (telegramUpdated ? '. Bot display name changed on Telegram too \u2705' : '.')\n      : 'Nothing to update \u2014 no fields provided.'\n  }\n}];"
      },
      "id": "__NODE_7__",
