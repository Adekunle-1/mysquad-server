    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE table_2\ncolumn_1 CASE WHEN NULLIF($3, '') IS NOT NULL THEN $3 ELSE agent_name END,\n  tone_profile   = CASE WHEN NULLIF($4, '') IS NOT NULL\n                        THEN jsonb_set(\n                               COALESCE(tone_profile, '{}'::jsonb),\n                               '{tone_summary}',\n                               to_jsonb($4::text)\n                             )\n                        ELSE tone_profile END,\n  reply_language = CASE WHEN NULLIF($5, '') IS NOT NULL THEN $5 ELSE reply_language END,\n  updated_at     = now()\ncolumn_2 $1::uuid\n  column_3 $2::uuid\nRETURNING agent_name, tone_profile, reply_language, business_id",
        "options": {
          "queryReplacement": "={{ [\n  $json.business_id,\n  $json.tenant_id,\n  $json.agent_name    || '',\n  $json.tone_summary  || '',\n  $json.reply_language || ''\n] }}"
        }
      },
